BESTCHANGE_API_URL=https://your-bestchange-api.example.com/
BESTCHANGE_API_KEY=

# Optional aliases/settings:
# RATESCOPE_BESTCHANGE_API_URL=https://your-bestchange-api.example.com/
# RATESCOPE_ASSETS_FAST_TIMEOUT_MS=1500
# RATESCOPE_OFFERS_FAST_TIMEOUT_MS=8000

# Contact form SMTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=monik.exchange@gmail.com
SMTP_PASS=
CONTACT_RECEIVER=admin@monik.exchange

# Private accounts. Set strong passwords before deploying.
RATESCOPE_AUTH_SECRET=
RATESCOPE_ADMIN_EMAIL=admin@monik.exchange
RATESCOPE_ADMIN_PASSWORD=
RATESCOPE_OWNER_EMAIL=owner@monik.exchange
RATESCOPE_OWNER_PASSWORD=
RATESCOPE_USER_EMAIL=user@monik.exchange
RATESCOPE_USER_PASSWORD=

# Analytics. Fill only the counters you use.
NEXT_PUBLIC_YANDEX_METRIKA_ID=110119725
NEXT_PUBLIC_GOOGLE_ANALYTICS_ID=
NEXT_PUBLIC_GOOGLE_TAG_MANAGER_ID=

# Banner slots. Set ENABLED=0 to hide a slot. IMAGE can be a local /public path or an external URL.
RATESCOPE_BANNER_SITE_TOP_ENABLED=1
RATESCOPE_BANNER_SITE_TOP_TITLE=Разместите баннер на monik exchange
RATESCOPE_BANNER_SITE_TOP_TEXT=Покажите обменник аудитории, которая уже сравнивает курсы.
RATESCOPE_BANNER_SITE_TOP_HREF=/contacts#feedback
RATESCOPE_BANNER_SITE_TOP_IMAGE=
RATESCOPE_BANNER_SITE_TOP_BADGE=Реклама
RATESCOPE_BANNER_SITE_TOP_ALT=Баннер monik exchange

RATESCOPE_BANNER_MONITOR_TOP_ENABLED=0
RATESCOPE_BANNER_MONITOR_TOP_TITLE=
RATESCOPE_BANNER_MONITOR_TOP_TEXT=
RATESCOPE_BANNER_MONITOR_TOP_HREF=
RATESCOPE_BANNER_MONITOR_TOP_IMAGE=
RATESCOPE_BANNER_MONITOR_TOP_BADGE=
RATESCOPE_BANNER_MONITOR_TOP_ALT=

RATESCOPE_BANNER_CATALOG_TOP_ENABLED=0
RATESCOPE_BANNER_CATALOG_TOP_TITLE=
RATESCOPE_BANNER_CATALOG_TOP_TEXT=
RATESCOPE_BANNER_CATALOG_TOP_HREF=
RATESCOPE_BANNER_CATALOG_TOP_IMAGE=
RATESCOPE_BANNER_CATALOG_TOP_BADGE=
RATESCOPE_BANNER_CATALOG_TOP_ALT=

