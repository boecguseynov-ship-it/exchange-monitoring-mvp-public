{
  "name": "exchange-monitoring-mvp",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "load:smoke": "k6 run load/k6-smoke.js",
    "load:baseline": "k6 run -e PROFILE=baseline load/k6-smoke.js",
    "load:spike": "k6 run -e PROFILE=spike load/k6-smoke.js",
    "postinstall": "prisma generate",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:push": "prisma db push",
    "db:seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "6.19.3",
    "argon2": "^0.44.0",
    "lucide-react": "^0.468.0",
    "next": "16.2.9",
    "next-auth": "4.24.13",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "redis": "^5.12.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.57.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.3",
    "@types/react-dom": "^19.0.2",
    "eslint": "^9.17.0",
    "eslint-config-next": "16.2.9",
    "jsdom": "^25.0.1",
    "prisma": "6.19.3",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vercel": "^54.20.1",
    "vitest": "^2.1.8"
  },
  "overrides": {
    "postcss": "8.5.10",
    "uuid": "11.1.1"
  }
}
