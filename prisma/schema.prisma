generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum ExchangeStatus {
  ACTIVE
  PAUSED
  HIDDEN
}

enum ModerationStatus {
  PENDING
  PUBLISHED
  HIDDEN
  REJECTED
}

enum SupportStatus {
  NEW
  IN_PROGRESS
  RESOLVED
  SPAM
}

enum ComplaintStatus {
  OPEN
  WAITING_EXCHANGE
  WAITING_USER
  RESOLVED
  REJECTED
}

enum PublishStatus {
  DRAFT
  PUBLISHED
  HIDDEN
}

enum ApiCredentialStatus {
  ACTIVE
  REVOKED
}

model Exchange {
  id           String         @id @default(cuid())
  slug         String         @unique
  name         String
  domain       String         @unique
  description  String
  supportEmail String
  termsUrl     String?
  partnerUrl   String?
  insuranceDeposit String?
  noAml       Boolean        @default(false)
  status       ExchangeStatus @default(ACTIVE)
  isDemo       Boolean        @default(false)
  verifiedAt   DateTime?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  reviews      Review[]
  complaints   Complaint[]
  feeds        ExchangeFeed[]
  apiKeys      ApiCredential[]
  users        User[]
  rates        ExchangeRate[]
}

model ExchangeRate {
  id         String   @id @default(cuid())
  exchangeId String
  fromCode   String
  toCode     String
  rate       Float
  minAmount  Float    @default(1)
  reserve    Float    @default(0)
  enabled    Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  exchange   Exchange @relation(fields: [exchangeId], references: [id], onDelete: Cascade)

  @@unique([exchangeId, fromCode, toCode])
  @@index([exchangeId])
  @@index([enabled])
}

model Review {
  id             String           @id @default(cuid())
  exchangeId     String
  userId         String?
  authorName     String?
  source         String           @default("RATESCOPE")
  sourceId       String?
  transactionRef String?
  rating         Int
  body           String
  status         ModerationStatus @default(PENDING)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  exchange       Exchange         @relation(fields: [exchangeId], references: [id], onDelete: Cascade)
  user           User?            @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([exchangeId])
  @@index([status])
  @@index([source])
  @@unique([source, sourceId])
}

model User {
  id           String    @id @default(cuid())
  name         String?
  email        String?   @unique
  role         String    @default("USER")
  passwordHash String?
  exchangeId   String?
  exchange     Exchange? @relation(fields: [exchangeId], references: [id], onDelete: SetNull)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  reviews      Review[]

  @@index([exchangeId])
}

model WikiEntry {
  id          String   @id @default(cuid())
  title       String
  description String
  href        String
  anchor      String?
  group       String
  icon        String
  position    Int      @default(100)
  status      String   @default("PUBLISHED")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([group])
  @@index([status])
}

model ManagedAsset {
  id        String        @id @default(cuid())
  code      String        @unique
  name      String
  network   String?
  category  String        @default("other")
  status    PublishStatus @default(PUBLISHED)
  source    String        @default("admin")
  position  Int           @default(100)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@index([category])
  @@index([status])
}

model BlogPost {
  id          String        @id @default(cuid())
  slug        String        @unique
  title       String
  excerpt     String
  seoTitle    String?
  seoDescription String?
  ogTitle     String?
  ogDescription String?
  ogImage     String?
  body        String
  category    String
  readTime    String        @default("5 минут")
  accent      String        @default("#31d3a5")
  symbol      String        @default("R")
  status      PublishStatus @default(PUBLISHED)
  publishedAt DateTime      @default(now())
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([status])
  @@index([publishedAt])
}

model LegalDocument {
  id          String        @id @default(cuid())
  slug        String        @unique
  title       String
  description String
  body        String
  status      PublishStatus @default(PUBLISHED)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([status])
}

model Banner {
  id        String        @id @default(cuid())
  placement String       @unique
  title     String
  text      String
  href      String
  image     String?
  alt       String
  badge     String       @default("Реклама")
  status    PublishStatus @default(HIDDEN)
  position  Int          @default(100)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  @@index([status])
  @@index([position])
}

model DirectionSeoText {
  id        String        @id @default(cuid())
  slug      String        @unique
  title     String?
  body      String
  status    PublishStatus @default(PUBLISHED)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@index([status])
}

model ContactMessage {
  id        String        @id @default(cuid())
  name      String?
  email     String
  subject   String
  message   String
  status    SupportStatus @default(NEW)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@index([status])
  @@index([createdAt])
}

model Complaint {
  id             String          @id @default(cuid())
  exchangeId     String
  transactionRef String?
  type           String          @default("PAYMENT_DELAY")
  authorEmail    String?
  message        String
  moderatorNote  String?
  status         ComplaintStatus @default(OPEN)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  exchange       Exchange        @relation(fields: [exchangeId], references: [id], onDelete: Cascade)

  @@index([exchangeId])
  @@index([status])
}

model AuditLog {
  id         String   @id @default(cuid())
  action     String
  actor      String   @default("admin@ratescope.local")
  targetType String
  targetId   String?
  details    String?
  createdAt  DateTime @default(now())

  @@index([createdAt])
  @@index([targetType])
}

model ExchangeFeed {
  id           String   @id @default(cuid())
  exchangeId   String
  pullUrl      String?
  intervalSec  Int      @default(300)
  enabled      Boolean  @default(true)
  lastPulledAt DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  exchange     Exchange @relation(fields: [exchangeId], references: [id], onDelete: Cascade)

  @@unique([exchangeId])
  @@index([enabled])
}

model ApiCredential {
  id         String              @id @default(cuid())
  exchangeId String
  label      String
  tokenHint  String
  status     ApiCredentialStatus @default(ACTIVE)
  createdAt  DateTime            @default(now())
  revokedAt  DateTime?
  exchange   Exchange            @relation(fields: [exchangeId], references: [id], onDelete: Cascade)

  @@index([exchangeId])
  @@index([status])
}
